{
  "name": "agenthandoff",
  "version": "0.1.0",
  "description": "Local-first handoff packets for humans and coding agents.",
  "type": "module",
  "bin": {
    "agenthandoff": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/src",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "handoff",
    "cli",
    "git",
    "local-first",
    "automation"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agenthandoff.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agenthandoff/issues"
  },
  "homepage": "https://github.com/rogerchappel/agenthandoff#readme"
}
